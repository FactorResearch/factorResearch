    {"id":"provider-circuit-open","severity":"high","owner":"data-platform","condition":"provider circuit open for 10m or provider error ratio > 0.20 for 10m","runbook":"runbooks/provider.md"},
    {"id":"analysis-backlog","severity":"high","owner":"platform","condition":"oldest queued job > 300s or dead_letter > 0","runbook":"runbooks/queue.md"},
    {"id":"authentication-failure","severity":"critical","owner":"security","condition":"authentication failure ratio > 0.10 for 5m","runbook":"runbooks/authentication.md"},
    {"id":"billing-webhook-delay","severity":"high","owner":"payments","condition":"oldest unprocessed webhook > 300s or verification failure > 0","runbook":"runbooks/billing.md"},

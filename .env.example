# Authentication Environment Variables Examples

# Copy the appropriate example below to your .env file or deployment configuration

# ============================================================================
# LOCAL DEVELOPMENT (No Auth - Session-based UUIDs)
# ============================================================================
# No AUTH_PROVIDER needed. App uses session-based UUIDs automatically.
# This is for development and testing only.

FLASK_ENV=development
FLASK_DEBUG=1


# ============================================================================
# AUTH0 PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your_client_id_from_auth0_dashboard
AUTH0_CLIENT_SECRET=your_client_secret_from_auth0_dashboard
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here

# Steps to get these values:
# 1. Go to https://auth0.com and create an account
# 2. Create a new Regular Web Application
# 3. In Settings tab, copy:
#    - Domain: shown at top of page (e.g., yourapp.auth0.com)
#    - Client ID: under "Basic Information"
#    - Client Secret: under "Basic Information"
# 4. In "Allowed Callback URLs" add: https://yourapp.com/callback
# 5. In "Allowed Logout URLs" add: https://yourapp.com/


# ============================================================================
# CLERK PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=clerk
CLERK_PUBLIC_KEY=pk_live_your_public_key_here
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here

# Steps to get these values:
# 1. Go to https://clerk.com and create an account
# 2. Create a new application
# 3. Go to API Keys section
# 4. Copy the Publishable Key (pk_live_...)
# 5. Configure redirect URIs in your application settings


# ============================================================================
# SUPABASE AUTH PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here

# Steps to get these values:
# 1. Go to https://supabase.com and create an account
# 2. Create a new project
# 3. Go to Settings > API
# 4. Copy:
#    - Project URL (should look like https://xxxxx.supabase.co)
#    - anon/public key (the API key for frontend access)
# 5. Go to Authentication > Providers to enable OAuth (Google, GitHub, etc.)


# ============================================================================
# FLASK CONFIGURATION (All Environments)
# ============================================================================

# Generate a secure key:
# python -c "import secrets; print(secrets.token_hex(32))"

FLASK_SECRET_KEY=your_secure_random_key_here_make_it_long

# For production, set this:
FLASK_ENV=production

# For development, set this:
FLASK_ENV=development


# ============================================================================
# DEPLOYMENT PLATFORMS
# ============================================================================

# --- Railway ---
# 1. Create a project
# 2. Add environment variables via Dashboard > Variables
# 3. Set each variable individually

# --- Heroku ---
# heroku config:set AUTH_PROVIDER=auth0
# heroku config:set AUTH0_DOMAIN=your-domain.auth0.com
# etc.

# --- Docker ---
# Build with: docker build -t graham-app .
# Run with:
#   docker run -e AUTH_PROVIDER=auth0 \
#     -e AUTH0_DOMAIN=xxx.auth0.com \
#     -e AUTH0_CLIENT_ID=xxx \
#     -e AUTH0_CLIENT_SECRET=xxx \
#     -p 8050:8050 \
#     graham-app

# --- Docker Compose ---
# See docker-compose.yml for example configuration

# --- AWS Lambda / API Gateway ---
# Set environment variables in Lambda function configuration
# Make sure to configure API Gateway with proper CORS headers

# --- Google Cloud Run ---
# gcloud run deploy graham-app \
#   --set-env-vars=AUTH_PROVIDER=auth0,AUTH0_DOMAIN=xxx,...

# --- Azure Container Instances ---
# Set environment variables in container configuration

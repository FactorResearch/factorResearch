# Authentication Environment Variables Examples

# Copy the appropriate example below to your .env file or deployment configuration
# IMPORTANT: Never commit .env to git! Add to .gitignore

# ============================================================================
# LOCAL DEVELOPMENT (No Auth - Session-based UUIDs)
# ============================================================================
# No AUTH_PROVIDER needed. App uses session-based UUIDs automatically.
# This is for development and testing only.

FLASK_ENV=development
FLASK_DEBUG=1
DISABLE_CSRF_DEV=0


# ============================================================================
# AUTH0 PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your_client_id_from_auth0_dashboard
AUTH0_CLIENT_SECRET=your_client_secret_from_auth0_dashboard
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here
ENCRYPTION_KEY=your_fernet_encryption_key_here
SECURITY_LOG_LEVEL=INFO

# Steps to get these values:
# 1. Go to https://auth0.com and create an account
# 2. Create a new Regular Web Application
# 3. In Settings tab, copy:
#    - Domain: shown at top of page (e.g., yourapp.auth0.com)
#    - Client ID: under "Basic Information"
#    - Client Secret: under "Basic Information"
# 4. In "Allowed Callback URLs" add: https://yourapp.com/callback
# 5. In "Allowed Logout URLs" add: https://yourapp.com/
# 6. Generate FLASK_SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
# 7. Generate ENCRYPTION_KEY:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"


# ============================================================================
# CLERK PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=clerk
CLERK_PUBLIC_KEY=pk_live_your_public_key_here
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here
ENCRYPTION_KEY=your_fernet_encryption_key_here
SECURITY_LOG_LEVEL=INFO

# Steps to get these values:
# 1. Go to https://clerk.com and create an account
# 2. Create a new application
# 3. Go to API Keys section
# 4. Copy the Publishable Key (pk_live_...)
# 5. Configure redirect URIs in your application settings
# 6. Generate FLASK_SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
# 7. Generate ENCRYPTION_KEY:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"


# ============================================================================
# SUPABASE AUTH PRODUCTION CONFIGURATION
# ============================================================================
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
CALLBACK_URL=https://yourapp.com/callback
FLASK_ENV=production
FLASK_SECRET_KEY=your_secure_random_key_here
ENCRYPTION_KEY=your_fernet_encryption_key_here
SECURITY_LOG_LEVEL=INFO

# Steps to get these values:
# 1. Go to https://supabase.com and create an account
# 2. Create a new project
# 3. Go to Settings > API
# 4. Copy:
#    - Project URL (should look like https://xxxxx.supabase.co)
#    - anon/public key (the API key for frontend access)
# 5. Go to Authentication > Providers to enable OAuth (Google, GitHub, etc.)
# 6. Generate FLASK_SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
# 7. Generate ENCRYPTION_KEY:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"


# ============================================================================
# FLASK & SECURITY CONFIGURATION (All Environments)
# ============================================================================

# Flask environment
FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: Use different key for each environment (dev/staging/prod)
FLASK_SECRET_KEY=your_secure_random_key_here_min_32_chars

# Encryption key for sensitive data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Security logging level
SECURITY_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Disable CSRF in development (only! Never in production)
DISABLE_CSRF_DEV=0


# ============================================================================
# DATABASE CONFIGURATION (Production)
# ============================================================================

# PostgreSQL connection string (optional, uses SQLite if not set)
# Format: postgresql://user:password@host:port/dbname
# IMPORTANT: Use strong password (20+ chars), rotate regularly
DATABASE_URL=postgresql://user:secure_password_here@localhost:5432/graham_app


# ============================================================================
# EXTERNAL API KEYS
# ============================================================================

# Alpha Vantage (Stock price data)
# Get from: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_api_key_here

# Finnhub (Financial data)
# Get from: https://finnhub.io/
FINNHUB_API_KEY=your_api_key_here

# Stripe (If using billing)
# Get from: https://stripe.com/
# STRIPE_SECRET_KEY=sk_live_your_key_here
# STRIPE_PRICE_ID=price_your_price_id


# ============================================================================
# DEPLOYMENT PLATFORMS
# ============================================================================

# --- Railway ---
# 1. Create a project
# 2. Add environment variables via Dashboard > Variables
# 3. Set each variable individually

# --- Heroku ---
# heroku config:set AUTH_PROVIDER=auth0
# heroku config:set AUTH0_DOMAIN=your-domain.auth0.com
# etc.

# --- Docker ---
# Build with: docker build -t graham-app .
# Run with:
#   docker run \
#     -e AUTH_PROVIDER=auth0 \
#     -e AUTH0_DOMAIN=xxx.auth0.com \
#     -e AUTH0_CLIENT_ID=xxx \
#     -e AUTH0_CLIENT_SECRET=xxx \
#     -e FLASK_SECRET_KEY=xxx \
#     -e ENCRYPTION_KEY=xxx \
#     -p 8050:8050 \
#     graham-app

# --- Docker Compose ---
# See docker-compose.yml for example configuration

# --- AWS Lambda / API Gateway ---
# Set environment variables in Lambda function configuration
# Use AWS Secrets Manager for sensitive values:
#   aws secretsmanager create-secret --name graham-app/secrets --secret-string '{"FLASK_SECRET_KEY":"...","ENCRYPTION_KEY":"..."}'

# --- Google Cloud Run ---
# gcloud run deploy graham-app \
#   --set-env-vars=AUTH_PROVIDER=auth0,AUTH0_DOMAIN=xxx,...

# --- Azure Container Instances ---
# Set environment variables in container configuration
# Use Azure Key Vault for secrets


# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================

# ✅ DO:
# - Use strong, random secrets (20+ characters, mixed case, numbers, symbols)
# - Generate different secrets for dev, staging, and production
# - Rotate secrets quarterly (minimum)
# - Store secrets in secure vault (AWS Secrets Manager, Azure Key Vault, etc.)
# - Use HTTPS only in production
# - Enable MFA on all accounts with access to secrets
# - Review and restrict database user permissions
# - Use temporary credentials for third-party access (rotate frequently)
# - Monitor and alert on failed authentication attempts
# - Keep dependencies updated and check for vulnerabilities

# ❌ DON'T:
# - Commit .env to git (add to .gitignore)
# - Share secrets in Slack/email/chat
# - Use simple or predictable passwords
# - Reuse secrets across environments
# - Store secrets in code comments
# - Run with debug mode enabled in production
# - Allow public access to admin functions
# - Trust user input without validation
# - Expose sensitive data in error messages or logs
# - Disable CSRF protection
# - Use HTTP in production

